generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id        Int       @id @default(autoincrement())
  name      String
  cnpj      String    @unique
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  category  String
  contact   String?
  email     String?
  active    Boolean   @default(true)
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Invoice {
  id          Int          @id @default(autoincrement())
  supplierId  Int
  supplier    Supplier     @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  companyId   Int
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category    String
  amount      Decimal
  issueDate   DateTime
  dueDate     DateTime
  paidAt      DateTime?
  notes       String?
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([companyId])
  @@index([supplierId])
  @@index([dueDate])
}

model Attachment {
  id           Int      @id @default(autoincrement())
  invoiceId    Int
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  @@index([invoiceId])
}

model Webhook {
  id            Int      @id @default(autoincrement())
  name          String
  url           String
  events        String
  active        Boolean  @default(true)
  lastTriggerAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
